"│cron                        ││Description: cron.service description [?]                                               │"
"│docker                      ││     Active: active (running)                                                           │"
"│nginx                       ││ Enablement: enabled · global                                                           │"
"│bad-config                  ││  Unit file: /etc/systemd/system/cron.service                                           │"
"│backup.timer                │╰────────────────────────────────────────────────────────────────────────────────────────╯"
"│ssh                         │╭─Service Logs [newest first; ctrl+r to reverse]─────────────────────────────────────────╮"
"│                            ││    ╭─Help for systemctl-tui v0.6.1──────────────────╮                                  │"
"│                            ││    │                                                │                                  │"
"│                            ││    │Shortcuts                                       │                                  │"
"│                            ││    │                                                │                                  │"
"│                            ││    │ctrl+C or ctrl+Q to quit                        │                                  │"
"│                            ││    │ctrl+L toggles the logger pane                  │                                  │"
"│                            ││    │ctrl+R reverses the log order                   │                                  │"
"│                            ││    │PageUp / PageDown scroll the logs               │                                  │"
"│                            ││    │Home / End scroll to top/bottom                 │                                  │"
"│                            ││    │Enter or Space open the action menu             │                                  │"
"│                            ││    │f filter services by status                     │                                  │"
"│                            ││    │? / F1 open this help pane                      │                                  │"
"│                            ││    │mouse: drag to select+copy logs, wheel to scroll│                                  │"
