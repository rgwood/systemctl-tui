# Machines that receive the x86_64 Linux binary, separated by commas.
PUBLISH_X86_64_HOSTS=example-x86-host

# Machines that receive the ARM64 Linux binary, separated by commas.
PUBLISH_AARCH64_HOSTS=example-arm-host

# Where to install the binary on this laptop.
PUBLISH_LOCAL_DESTINATION=~/bin

# Where to install the binary on each remote machine.
PUBLISH_REMOTE_DESTINATION=~/bin/
